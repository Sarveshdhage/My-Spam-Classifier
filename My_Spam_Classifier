    "import pandas as pd\n",
    "\n",
    "# Load the real dataset from Kaggle\n",
    "# encoding='latin-1' is used because text files often have special characters\n",
    "df_real = pd.read_csv('spam.csv', encoding='latin-1')\n",
    "\n",
    "# Kaggle dataset has extra columns, let's keep only what we need\n",
    "df_real = df_real[['v1', 'v2']]\n",
    "df_real.columns = ['label', 'text']\n",
    "\n",
    "# Map 'spam' to 1 and 'ham' to 0\n",
    "df_real['label'] = df_real['label'].map({'spam': 1, 'ham': 0})\n",
    "\n",
    "print(\"Real Dataset Loaded Successfully!\")\n",
    "print(df_real.head()) # Shows first 5 rows"
